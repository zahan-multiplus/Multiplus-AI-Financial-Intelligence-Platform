title AI Intelligence Processing Pipeline
participant "Structured\nFinancial Data" as Data
participant "Financial Data\nInterpretation" as Interp
participant "User Financial\nProfile Construction" as Profile
participant "Portfolio\nIntelligence" as Portfolio
participant "Risk\nProfiling" as Risk
